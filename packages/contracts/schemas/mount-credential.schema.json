{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://betternas.local/schemas/mount-credential.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "username", "password", "expiresAt"],
  "properties": {
    "mode": {
      "const": "basic-auth"
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "expiresAt": {
      "type": "string"
    }
  }
}
