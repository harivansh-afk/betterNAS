{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://betternas.local/schemas/cloud-profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "exportId", "provider", "baseUrl", "path"],
  "properties": {
    "id": {
      "type": "string"
    },
    "exportId": {
      "type": "string"
    },
    "provider": {
      "const": "nextcloud"
    },
    "baseUrl": {
      "type": "string"
    },
    "path": {
      "type": "string"
    }
  }
}
